{
  "name": "ai-trading-stack",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter @ai-trading/db db:push",
    "db:studio": "pnpm --filter @ai-trading/db db:studio",
    "demo": "pnpm exec tsx scripts/demo.ts"
  },
  "dependencies": {
    "@ai-trading/backtest": "workspace:*",
    "@ai-trading/db": "workspace:*",
    "@ai-trading/execution": "workspace:*",
    "@ai-trading/risk": "workspace:*",
    "@ai-trading/shared": "workspace:*",
    "@ai-trading/signals": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  }
}
